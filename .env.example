# Slack Incoming Webhook URL
# Create one at: https://api.slack.com/apps -> Your App -> Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Formula 1 bot settings
# How many hours before a session to send the first reminder (default: 24)
REMINDER_HOURS_EARLY=24

# How many minutes before a session to send the final reminder (default: 30)
REMINDER_MINUTES_FINAL=30

# Optional: filter to specific session types (comma-separated)
# Options: Practice, Qualifying, Sprint Qualifying, Sprint, Race
SESSION_FILTER=

# Shared timezone
TIMEZONE=America/New_York

# Optional shared healthcheck for the F1 bot
HEALTHCHECK_URL=

# IPL bot settings
# Cricket Data API key
# Create one at: https://cricketdata.org/
CRICKETDATA_API_KEY=YOUR_CRICKETDATA_API_KEY

# IPL season and series id
IPL_SEASON=2025
IPL_SERIES_ID=d5a498c8-7596-4b93-8ab0-e0efc3345312

# Optional IPL-specific overrides.
IPL_SLACK_WEBHOOK_URL=
IPL_TIMEZONE=

# Night-before preview send time in local timezone (24h clock)
PRE_GAME_LOCAL_HOUR=22

# Minutes before start for the toss + lineup notification
PRE_MATCH_MINUTES=15

# Estimated offsets from scheduled start for the remaining sends
MID_INNINGS_OFFSET_MINUTES=125
POST_MATCH_OFFSET_MINUTES=250

# Retry cadence while waiting for toss / innings break / match result
RETRY_INTERVAL_MINUTES=5

# Set to true if you want to refetch and overwrite the stored season schedule
FORCE_SYNC_SCHEDULE=false

# --- Podcast (F1 post-race audio analysis) ---
# Ollama endpoint and model for script generation (no API key needed)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# mlx-audio TTS server (shared with VibeBot)
TTS_URL=http://localhost:8080
TTS_MODEL=mlx-community/Kokoro-82M-bf16
TTS_VOICE=af_heart

# Where to save MP3s and how to serve them (shared with VibeBot)
PODCAST_SERVE_URL=http://100.104.18.70:8888
PODCAST_OUTPUT_DIR=~/VibeBot-Podcasts

# Minutes after race end to fire the podcast notification (default: 90)
PODCAST_DELAY_MINUTES=90
